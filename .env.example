NODE_ENV=production

# Database
DB_ROOT_PASSWORD=changeme_root
DB_NAME=mopsy
DB_USER=mopsy_user
DB_PASSWORD=changeme_db

# Backend
BACKEND_PORT=3001

# Frontend (Nginx listens on 80 inside container)
FRONTEND_PORT=3000

# JWT
JWT_ACCESS_SECRET=changeme_access_secret_min_32_chars
JWT_REFRESH_SECRET=changeme_refresh_secret_min_32_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Mail Settings
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=noreply@mopsy.app
MAIL_PASS=changeme_mail_password
MAIL_FROM="Mopsy <noreply@mopsy.app>"
APP_URL=https://test.bellaclean.co.uk

# Schedule auto-generation
SCHEDULE_LOOKAHEAD_MONTHS=6

# Pause request buffer
PAUSE_BUFFER_HOURS=24

# File uploads
UPLOAD_BASE_PATH=uploads
MAX_PHOTO_SIZE_MB=10

# Puppeteer / PDF
CHROMIUM_PATH=/usr/bin/chromium

# Google Drive (Service Account)
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=backend/info/service-account-key.json
GOOGLE_DRIVE_ROOT_FOLDER_ID=your_drive_folder_id_here

# Invoice settings
INVOICE_DUE_DAYS=14

